# Streamlit Secrets Template
# Copy this to .streamlit/secrets.toml (local) or add to Streamlit Cloud secrets

# Stripe API Keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY = "sk_test_YOUR_KEY_HERE"
STRIPE_PUBLISHABLE_KEY = "pk_test_YOUR_KEY_HERE"

# Stripe Webhook Secret (optional - for production)
STRIPE_WEBHOOK_SECRET = "whsec_YOUR_KEY_HERE"

# Stripe Price IDs (create products in Stripe Dashboard first)
STRIPE_PRICE_AI_WEEKLY = "price_YOUR_WEEKLY_PRICE_ID"
STRIPE_PRICE_AI_MONTHLY = "price_YOUR_MONTHLY_PRICE_ID"
STRIPE_PRICE_NEWSLETTER = "price_YOUR_NEWSLETTER_PRICE_ID"
STRIPE_PRICE_REAL_MONEY = "price_YOUR_REAL_MONEY_PRICE_ID"

# App URL
APP_URL = "https://tradeai-signals.streamlit.app"